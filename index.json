const { fork } = require('child_process');
const { join } = require('path');
const fs = require('fs-extra');
const chalk = require('chalk');
const logger = require('./utils/console');

const cyan = chalk.cyanBright;
const red = chalk.redBright;
const gray = chalk.gray;

const maxRetries = 3;
const retryDelay = 5000;

let isRunning = false;
let retryCount = 0;

function showFancyHeader() {
    console.clear();
    console.log(gray('┌────────────────────────────────────────────────────────┐'));
    console.log(gray('│') + cyan.bold('                𝐓 𝐑 𝐀 𝐔 𝐌 𝐀  𝐔 𝐋 𝐓 𝐑 𝐀                ') + gray('│'));
    console.log(gray('├────────────────────────────────────────────────────────┤'));
    console.log(gray('│') + cyan('  [SYSTEM] : STARTING CORE...                           ') + gray('│'));
    console.log(gray('│') + cyan('  [STATUS] : BOOTING DATABASE...                        ') + gray('│'));
    console.log(gray('└────────────────────────────────────────────────────────┘\n'));
}

function handleConnection(retry = 0) {
    const currentPath = process.cwd();
    const connectionFolder = join(currentPath, 'ملف_الاتصال');

    if (!fs.existsSync(connectionFolder)) {
        logger.warn(cyan('[!] Connection folder not found.'));
    }

    if (isRunning) return;
    isRunning = true;

    showFancyHeader();

    const child = fork(join(__dirname, 'main.js'), [], {
        stdio: ['inherit', 'inherit', 'inherit', 'ipc'],
        env: {
            ...process.env,
            CONNECTION_FOLDER: connectionFolder
        }
    });

    child.on('message', (data) => {
        if (data === 'ready') {
            retryCount = 0;
            console.log(cyan.bold('>>> 𝐓𝐑𝐀𝐔𝐌𝐀 𝐔𝐋𝐓𝐑𝐀 ONLINE.'));
        } else if (data === 'reset') {
            console.log(gray('>>> REBOOTING SYSTEM...'));
            child.kill();
            setTimeout(() => handleConnection(0), 2000);
        } else if (data === 'uptime') {
            child.send(process.uptime());
        }
    });

    child.on('exit', async (code) => {
        isRunning = false;

        if (code === 0) {
            console.log(gray('>>> PROCESS HALTED.'));
            return;
        }

        if (code === 429) {
            console.log(red('>>> OVERLOAD DETECTED. COOLING DOWN...'));
            await delay(10000);
            return handleConnection(retry);
        }

        if (retry < maxRetries) {
            retry++;
            console.log(red(`>>> RE-EXECUTING [${retry}/${maxRetries}]...`));
            await delay(retryDelay);
            handleConnection(retry);
        } else {
            console.log(red('>>> FATAL ERROR: RE-EXECUTION FAILED.'));
            process.exit(1);
        }
    });

    child.on('error', (err) => {
        isRunning = false;
        console.log(red(`>>> CRITICAL EXCEPTION: ${err}`));
        if (retry < maxRetries) {
            retry++;
            setTimeout(() => handleConnection(retry), retryDelay);
        }
    });

    setTimeout(() => {
        if (!child.connected) {
            console.log(red('>>> TIMEOUT: NO RESPONSE FROM CORE.'));
            child.kill();
            handleConnection(retry + 1);
        }
    }, 10000);
}

function delay(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
}

process.on('SIGINT', () => process.exit());

process.on('uncaughtException', (err) => {
    if (err.code === 'ECONNRESET' || err.code === 'rate-overlimit') return;
    console.log(red('>>> SYSTEM ERROR:'), err);
});

process.on('unhandledRejection', (reason) => {
    if (reason?.code === 429) return;
    console.log(red('>>> REJECTION ERROR:'), reason);
});

console.log(cyan('>>> STARTING BOOT SEQUENCE...'));
handleConnection();
